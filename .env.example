# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# The domain everything lives on (public links at /<token>, admin at /admin)
PUBLIC_HOST=garage.asafshilo.com

# Home Assistant webhook that opens the gate (the webhook id is a secret).
# Production: this app shares network_mode: host with Home Assistant on the
# same box, so use http://localhost:8123/api/webhook/<id>.
# Local dev: use http://yofiserver:8123/api/webhook/<id> instead (resolved
# to HA's Tailscale IP by docker-compose.local.yml's extra_hosts).
HA_WEBHOOK_URL=

# Google OAuth (from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google account emails allowed into the admin panel
ALLOWED_EMAILS=you@example.com

# SQLite location (leave as-is inside Docker; the compose file mounts a volume there)
DB_PATH=/data/links.db

# Local development ONLY: allow plain-http sessions so Google login works from
# http://localhost. NEVER set this in production.
#INSECURE_HTTP=1
